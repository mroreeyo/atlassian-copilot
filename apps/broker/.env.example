# Broker-only secrets. Do not create VITE_* secret variables.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Env fallback stays opt-in; personal /settings keys are enabled by the saved setting.
AKC_ENABLE_LIVE_OPENAI=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
AKC_ENABLE_LIVE_ANTHROPIC=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
AKC_ENABLE_LIVE_OPENROUTER=false
OPENROUTER_HTTP_REFERER=http://localhost:5180
OPENROUTER_APP_TITLE=Atlassian Copilot
ATLASSIAN_URL=https://your-sandbox.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=
JIRA_PROJECT_ALLOWLIST=AKC,NFS
CONFLUENCE_SPACE_ALLOWLIST=AKC
COPILOT_MODE=readonly
SANDBOX_WRITE_ENABLED=false
BROKER_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5180,http://127.0.0.1:5180

# Auth / Google OAuth (Broker-only). Google auth stays fail-closed until DB sessions, CSRF, and user-scoped stores pass gates.
AKC_AUTH_BASE_URL=http://localhost:8787
AKC_WEB_BASE_URL=http://localhost:5173
AKC_ENABLE_GOOGLE_AUTH=false
# Production default is local auth disabled unless AKC_ENABLE_LOCAL_AUTH=true is set deliberately.
AKC_ENABLE_LOCAL_AUTH=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback
GOOGLE_ALLOWED_HOSTED_DOMAIN=
AKC_AUTH_CSRF_SECRET=
AKC_CREDENTIAL_ENCRYPTION_KEY=
AKC_AUTH_SESSION_TTL_HOURS=168
AKC_AUTH_SESSION_IDLE_TTL_MINUTES=60
AKC_AUTH_OAUTH_TRANSACTION_TTL_MINUTES=10
AKC_AUTH_DB_PATH=.akc-state/auth.sqlite
# Test/local CLI clients may opt in to sourceless mutations outside production only.
AKC_ALLOW_SOURCELESS_MUTATIONS=false
