# Broker-only secrets. Do not create VITE_* secret variables.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Env fallback stays opt-in; personal /settings keys are enabled by the saved setting.
AKC_ENABLE_LIVE_OPENAI=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
AKC_ENABLE_LIVE_ANTHROPIC=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
AKC_ENABLE_LIVE_OPENROUTER=false
OPENROUTER_HTTP_REFERER=http://localhost:5180
OPENROUTER_APP_TITLE=AX Knowledge Copilot
ATLASSIAN_URL=https://your-sandbox.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=
JIRA_PROJECT_ALLOWLIST=AKC,NFS
CONFLUENCE_SPACE_ALLOWLIST=AKC
COPILOT_MODE=readonly
SANDBOX_WRITE_ENABLED=false
BROKER_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5180,http://127.0.0.1:5180
